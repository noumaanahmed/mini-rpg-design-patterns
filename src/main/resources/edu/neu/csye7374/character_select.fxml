<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600" prefWidth="800"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.neu.csye7374.javafx.FXCharacterSelectController">

    <children>

        <!-- Background -->
        <ImageView fitHeight="600" fitWidth="800"
                   preserveRatio="false"
                   AnchorPane.topAnchor="0"
                   AnchorPane.leftAnchor="0"
                   AnchorPane.bottomAnchor="0"
                   AnchorPane.rightAnchor="0">
            <image>
                <Image url="@assets/backgrounds/character_select_bg.png"/>
            </image>
        </ImageView>

        <!-- Main Layout -->
        <VBox alignment="CENTER" spacing="25"
              AnchorPane.topAnchor="40"
              AnchorPane.leftAnchor="0"
              AnchorPane.rightAnchor="0">

            <!-- Character Selection Row -->
            <HBox alignment="CENTER" spacing="120">

                <!-- WARRIOR -->
                <VBox fx:id="warriorBox"
                      alignment="CENTER"
                      spacing="10"
                      styleClass="char-box">

                    <!-- Sprite Container -->
                    <StackPane prefWidth="180" prefHeight="240" alignment="CENTER">
                        <ImageView fx:id="warriorImage"
                                   fitWidth="180"
                                   fitHeight="180"
                                   preserveRatio="true"/>
                    </StackPane>

                    <!-- Label -->
                    <Label text="Warrior" styleClass="char-label"/>
                </VBox>

                <!-- MAGE -->
                <VBox fx:id="mageBox"
                      alignment="CENTER"
                      spacing="10"
                      styleClass="char-box">

                    <!-- Sprite Container -->
                    <StackPane prefWidth="180" prefHeight="240" alignment="CENTER">
                        <ImageView fx:id="mageImage"
                                   fitWidth="180"
                                   fitHeight="180"
                                   preserveRatio="true"/>
                    </StackPane>

                    <!-- Label -->
                    <Label text="Mage" styleClass="char-label"/>
                </VBox>

            </HBox>

            <!-- UI Controls -->
            <Label text="Create Your Character"
                   style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: white;"/>

            <TextField fx:id="nameField"
                       promptText="Enter name"
                       maxWidth="260"/>

            <ComboBox fx:id="difficultyBox"
                      promptText="Select Difficulty"
                      maxWidth="200"/>

            <Button fx:id="startButton"
                    text="Begin Battle"
                    onAction="#onStartBattle"
                    style="-fx-font-size: 18; -fx-padding: 10 20;"/>

        </VBox>

    </children>

</AnchorPane>
