<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.ScrollPane?>


<BorderPane prefHeight="600" prefWidth="900"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.neu.csye7374.javafx.FXBattleController">

    <!-- CENTER: battlefield + logs -->
    <center>
        <VBox alignment="CENTER" spacing="10" BorderPane.alignment="CENTER">

            <!-- Battlefield area -->
            <Pane fx:id="battlePane" prefHeight="380" prefWidth="900">

                <!-- Background, stretched to full width -->
                <ImageView fitHeight="600.0" fitWidth="900" preserveRatio="false">
                    <image>
                        <Image url="@assets/backgrounds/character_select_bg.png" />
                    </image>
                </ImageView>

                <!-- HERO HP BAR (background + fill) ABOVE TEXT -->
                <Pane fx:id="heroHpBarBg"
                      layoutX="160" layoutY="145"
                      prefWidth="140" prefHeight="12"
                      style="-fx-background-color: rgba(0,0,0,0.65); -fx-background-radius: 6;">
                    <children>
                        <Pane fx:id="heroHpBarFill"
                              prefWidth="140" prefHeight="12"
                              style="-fx-background-color: #fb8c00; -fx-background-radius: 6;" />
                    </children>
                </Pane>

                <!-- ENEMY HP BAR (background + fill) ABOVE TEXT -->
                <Pane fx:id="enemyHpBarBg"
                      layoutX="620" layoutY="145"
                      prefWidth="140" prefHeight="12"
                      style="-fx-background-color: rgba(0,0,0,0.65); -fx-background-radius: 6;">
                    <children>
                        <Pane fx:id="enemyHpBarFill"
                              prefWidth="140" prefHeight="12"
                              style="-fx-background-color: #fb8c00; -fx-background-radius: 6;" />
                    </children>
                </Pane>

                <!-- HERO HP LABEL BELOW BAR -->
                <Label fx:id="heroHp"
                       layoutX="160" layoutY="165"
                       text="HP"
                       style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: white;
                              -fx-effect: dropshadow(one-pass-box, black, 4, 0, 0, 0);" />

                <!-- ENEMY HP LABEL BELOW BAR -->
                <Label fx:id="enemyHp"
                       layoutX="620" layoutY="165"
                       text="HP"
                       style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: white;
                              -fx-effect: dropshadow(one-pass-box, black, 4, 0, 0, 0);" />

                <!-- HERO MANA LABEL (for Mage only) -->
                <Label fx:id="heroManaLabel"
                       layoutX="160" layoutY="190"
                       text="Mana: 0/0"
                       style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #4fc3f7;
                              -fx-effect: dropshadow(one-pass-box, black, 4, 0, 0, 0);" />

                <!-- HERO MANA BAR (background + fill) -->
                <Pane fx:id="manaBarBg"
                      layoutX="160" layoutY="210"
                      prefWidth="160" prefHeight="10"
                      style="-fx-background-color: rgba(0,0,0,0.6); -fx-background-radius: 5;">
                    <children>
                        <Pane fx:id="manaBarFill"
                              prefWidth="160" prefHeight="10"
                              style="-fx-background-color: #4fc3f7; -fx-background-radius: 5;" />
                    </children>
                </Pane>

                <!-- HERO SPRITE -->
                <ImageView fx:id="heroSprite"
                           fitWidth="170" layoutX="160" layoutY="200"
                           preserveRatio="true" />

                <!-- HEAL OVERLAY (STACKED ON TOP OF HERO, INITIALLY HIDDEN) -->
                <ImageView fx:id="heroHealOverlay"
                           fitWidth="190" layoutX="150" layoutY="170"
                           mouseTransparent="true"
                           preserveRatio="true"
                           visible="false" />

                <!-- GOBLIN SPRITE (FACES HERO VIA SCALEX IN CONTROLLER) -->
                <ImageView fx:id="enemySprite"
                           fitWidth="170" layoutX="620" layoutY="200"
                           preserveRatio="true" />

            </Pane>

<!-- BATTLE LOG WINDOW -->
<ScrollPane fx:id="logScroll"
            styleClass="log-scroll"
            prefHeight="120"
            maxHeight="120"
            fitToWidth="true"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED">


    <content>
        <VBox fx:id="logBox"
              alignment="TOP_LEFT"
              spacing="6"
              style="
                -fx-padding: 14;
                -fx-background-color: rgba(0,0,0,0.35);
                -fx-background-radius: 18;
                -fx-border-radius: 18;
                -fx-border-color: rgba(255,255,255,0.25);
                -fx-border-width: 1.2;
              ">
        </VBox>
    </content>
</ScrollPane>



        </VBox>
    </center>

    <!-- BOTTOM: ACTION BUTTONS -->
    <bottom>
        <HBox alignment="CENTER"
              prefHeight="90"
              spacing="20"
              style="-fx-padding: 10 0 20 0;"
              BorderPane.alignment="CENTER">

            <Button fx:id="swordButton"
                    onAction="#onSwordAttack"
                    style="-fx-font-size: 16; -fx-padding: 8 20;"
                    text="Attack" />

            <Button fx:id="fireballButton"
                    onAction="#onFireball"
                    style="-fx-font-size: 16; -fx-padding: 8 20;"
                    text="Fireball" />

            <Button fx:id="healButton"
                    onAction="#onHeal"
                    style="-fx-font-size: 16; -fx-padding: 8 20;"
                    text="Heal" />
        </HBox>
    </bottom>

</BorderPane>
